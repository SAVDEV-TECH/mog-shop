rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'savde388@gmail.com' || 
         request.auth.token.email.matches('.*@mogshop\\.com$')); // Add other admin domains/emails here
    }

    // Settings collection rules
    match /settings/{settingId} {
      allow read: if true; // Allow anyone to read settings (needed for delivery fees)
      allow write: if isAdmin(); // Only admins can update settings
    }

    // Products collection rules
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders collection rules
    match /orders/{orderId} {
      allow create: if request.auth != null; // Any logged in user can create an order
      allow read, update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    // Reviews collection rules
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }
  }
}
